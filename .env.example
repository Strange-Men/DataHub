# ==================================================
# DataHub Local Environment Template
# Copy this file to .env for local development.
# Never commit real secrets.
# ==================================================

# --------------------------------------------------
# Backend / Database
# --------------------------------------------------
DATABASE_URL=
DATAHUB_ENV=local

# --------------------------------------------------
# LLM Provider - for answer generation
# DeepSeek is OpenAI-compatible.
# Official base URL: https://api.deepseek.com
# --------------------------------------------------
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_deepseek_api_key_here
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=800

# Optional alias for SDKs/scripts that expect DEEPSEEK_API_KEY.
# Use the same value as LLM_API_KEY if needed.
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# --------------------------------------------------
# Embedding Provider - for vector retrieval
# Current DataHub production table uses pgvector Vector(1536).
# Keep mock as the safe default until real provider dimension/schema is verified.
# --------------------------------------------------
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-deterministic
EMBEDDING_DIMENSION=1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=3

# --------------------------------------------------
# Embedding Option A: SiliconFlow
# Basjoo二开阶段曾预留 Jina/SiliconFlow API Key。
# 注意：常见 BGE 模型多为 1024 维，切换前必须确认 DataHub 表结构或维度兼容。
# --------------------------------------------------
# EMBEDDING_PROVIDER=siliconflow
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_API_KEY=your_siliconflow_api_key_here
# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
# EMBEDDING_DIMENSION=1536

# --------------------------------------------------
# Embedding Option B: Jina
# 注意：Jina 模型维度可能与当前 Vector(1536) 不一致，切换前必须验证维度。
# --------------------------------------------------
# EMBEDDING_PROVIDER=jina
# EMBEDDING_BASE_URL=https://api.jina.ai/v1
# EMBEDDING_API_KEY=your_jina_api_key_here
# EMBEDDING_MODEL=jina-embeddings-v4
# EMBEDDING_DIMENSION=2048

# --------------------------------------------------
# Safety
# --------------------------------------------------
LOG_LEVEL=info
DEBUG=false
