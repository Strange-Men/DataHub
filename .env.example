# ==================================================
# DataHub local/Docker environment template.
# Copy to .env, replace local-only passwords, and never commit .env.
# ==================================================

# --------------------------------------------------
# Docker Compose ports and PostgreSQL
# --------------------------------------------------
POSTGRES_DB=datahub
POSTGRES_USER=datahub
# Required. Keep the template empty so Compose fails closed until .env supplies it.
# URL-reserved characters are supported by the backend entrypoint's encoding;
# when needed, quote/escape values according to Docker Compose dotenv rules.
POSTGRES_PASSWORD=
POSTGRES_PORT=5433
BACKEND_PORT=8000
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8000

# --------------------------------------------------
# Governance authentication and RBAC (P1/P2-M9.2)
# Local compatibility tests may explicitly use disabled. Docker deployments
# exposed beyond a trusted workstation should use token and set unique secrets.
# Empty role tokens make only that role unavailable; token mode requires at
# least one role and rejects duplicate values. Never commit the real values.
# --------------------------------------------------
DATAHUB_AUTH_MODE=disabled
DATAHUB_ADMIN_TOKEN=
DATAHUB_CLEANER_TOKEN=
DATAHUB_REVIEWER_TOKEN=
DATAHUB_SERVICE_TOKEN=
DATAHUB_VIEWER_TOKEN=

# --------------------------------------------------
# No-answer calibration and abstention gate (P1/P2-M9.4B)
# disabled: calculate metadata only and preserve legacy results.
# shadow: record decisions without suppressing Agent evidence.
# enforced: CustomerOpsAgent abstains when evidence is not reliable.
# Raw P1/P2/Unified retrieval always keeps candidates for diagnostics.
# Thresholds are calibrated per score semantics; Unified uses a normalized
# source-local threshold ratio and never compares raw P1/P2/RRF scores.
# --------------------------------------------------
DATAHUB_NO_ANSWER_MODE=disabled
P1_NO_ANSWER_MIN_SCORE=0.45
P2_NO_ANSWER_MIN_SCORE=0.55
UNIFIED_NO_ANSWER_MIN_SCORE=1.0
NO_ANSWER_MIN_EVIDENCE=1
NO_ANSWER_AMBIGUOUS_QUERY_MIN_LENGTH=4

# Compose assembles the container DATABASE_URL from POSTGRES_* variables.
# For non-Docker development, uncomment and adapt this local-only URL.
# DATABASE_URL=postgresql://datahub:<url-encoded-password>@127.0.0.1:5433/datahub

# --------------------------------------------------
# P2 Asset Storage (P2-M1 Material Ingestion)
# Compose mounts a named volume and supplies the container root. For non-Docker
# development, set an absolute ASSET_STORAGE_ROOT only in the ignored .env file.
# --------------------------------------------------
ASSET_STORAGE_BACKEND=local
ASSET_MAX_UPLOAD_BYTES=10485760

# --------------------------------------------------
# Optional LLM provider (not required for retrieval or Docker health)
# --------------------------------------------------
# LLM_PROVIDER=deepseek
# LLM_BASE_URL=https://api.deepseek.com
# LLM_API_KEY=
# LLM_MODEL=

# --------------------------------------------------
# Embedding Provider
# P1 and the P2 text bridge currently require 1536 dimensions. Mock is the safe
# keyless startup default, but it is not real semantic-release evidence.
# --------------------------------------------------
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-deterministic
EMBEDDING_DIMENSION=1536
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=3
# Leave empty in mock mode. The application derives the immutable P2 profile.
P2_EMBEDDING_PROFILE=

# --------------------------------------------------
# P2-M8.2 Unified Retrieval Shadow Gate
# All switches fail closed. Enabling the versioned API does not change the
# sealed P1 endpoint or the CustomerOpsAgent default retrieval path.
# --------------------------------------------------
UNIFIED_RETRIEVAL_ENABLED=false
P2_RETRIEVAL_ENABLED=false
UNIFIED_RETRIEVAL_SHADOW_MODE=false
# Independent Agent kill switch. Active Unified evidence requires this flag,
# both retrieval flags above, an explicit v2 request opt-in, and Shadow off.
CUSTOMEROPS_UNIFIED_RETRIEVAL_ENABLED=false
UNIFIED_RETRIEVAL_BRANCH_TIMEOUT_SECONDS=8
UNIFIED_RETRIEVAL_RRF_K=60
UNIFIED_RETRIEVAL_P2_ASSET_CHUNK_QUOTA=2

# --------------------------------------------------
# Real SiliconFlow acceptance profile
# Uncomment in the local .env and supply the secret only at runtime.
# --------------------------------------------------
# EMBEDDING_PROVIDER=siliconflow
# EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
# EMBEDDING_DIMENSION=1536
# P2_EMBEDDING_PROFILE=text_bridge:siliconflow:Qwen/Qwen3-Embedding-4B:1536

# --------------------------------------------------
# Jina requires a separately reviewed 1536-dimension compatibility plan.
# Do not point a 2048-dimensional model at the current Vector(1536) tables.
# --------------------------------------------------
# EMBEDDING_PROVIDER=jina
# EMBEDDING_BASE_URL=https://api.jina.ai/v1
# EMBEDDING_API_KEY=
# EMBEDDING_MODEL=jina-embeddings-v4
# EMBEDDING_DIMENSION=1536

# --------------------------------------------------
# Safety
# --------------------------------------------------
LOG_LEVEL=info
DEBUG=false
